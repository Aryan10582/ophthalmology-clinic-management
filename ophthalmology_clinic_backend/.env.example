PROJECT_NAME=Ophthalmology Clinic Management API
API_VERSION=0.1.0
ENVIRONMENT=development

# Database configuration
#
# Local development:
# Leave DATABASE_URL empty and use the POSTGRES_* variables below.
#
# Production deployments:
# Set DATABASE_URL to the full SQLAlchemy connection string provided by your host
# such as Render, Neon, Railway, or another PostgreSQL provider. When present,
# DATABASE_URL takes priority over the POSTGRES_* variables.
DATABASE_URL=

POSTGRES_SERVER=db
POSTGRES_PORT=5432
POSTGRES_USER=clinic
POSTGRES_PASSWORD=clinic
POSTGRES_DB=ophthalmology_clinic

# Generate a strong secret before deploying.
SECRET_KEY=change-me-to-a-random-string-with-at-least-32-characters
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080

BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173
LOG_LEVEL=INFO

# Development only. Keep false in production.
SEED_DEMO_DATA=false
