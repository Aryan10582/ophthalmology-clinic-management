PROJECT_NAME=Ophthalmology Clinic Management API
API_VERSION=0.1.0
ENVIRONMENT=development

POSTGRES_SERVER=db
POSTGRES_PORT=5432
POSTGRES_USER=clinic
POSTGRES_PASSWORD=clinic
POSTGRES_DB=ophthalmology_clinic

# Generate a strong secret before deploying.
SECRET_KEY=change-me-to-a-random-string-with-at-least-32-characters
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080

BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173
LOG_LEVEL=INFO
